# Enforce LF line endings across all platforms
* text=auto eol=lf

*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf

# Binary files — never convert
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.mp3    binary
*.mp4    binary
*.opus   binary
*.ico    binary
*.tar.gz binary