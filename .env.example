# EchoFox — example environment file (for Docker / Compose).
#
# Copy to .env and edit:
#     cp .env.example .env
#
# Any ECHOFOX_<SECTION>_<KEY> variable overrides the matching field in
# src/config.js — see README.md "Configuration reference" for the full map.

# ─── Timezone (IANA) ──────────────────────────────────────────────────────
TZ=Asia/Kolkata

# ─── Grafana credentials (only used by the `observability` profile) ───────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ─── EchoFox config overrides ─────────────────────────────────────────────
# ECHOFOX_BOT_PREFIX=.
# ECHOFOX_BOT_ADMINPREFIX=$
# ECHOFOX_BOT_PUBLIC=true
# ECHOFOX_RUNTIME_LOGLEVEL=info
# ECHOFOX_RUNTIME_PORT=3000

# ─── API keys (optional; commands auto-skip if empty) ─────────────────────
# ECHOFOX_APIS_OMDB_APIKEY=
# ECHOFOX_APIS_VIRUSTOTAL_APIKEY=
# ECHOFOX_APIS_ALIENVAULT_APIKEY=
# ECHOFOX_APIS_OPENAI_APIKEY=
# ECHOFOX_APIS_GEMINI_APIKEY=
