{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Worker Up",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "echofox_worker_up", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "type": "stat",
      "title": "Worker Restarts (5m)",
      "id": 2,
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "increase(echofox_worker_restarts_total[5m])", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 3 }
          ] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Process RSS",
      "id": 3,
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "process_resident_memory_bytes", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "stat",
      "title": "Event Loop Lag (p99)",
      "id": 4,
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nodejs_eventloop_lag_p99_seconds", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.05 },
            { "color": "red", "value": 0.2 }
          ] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "id": 5,
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "process_uptime_seconds{job=\"echofox\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Node.js Version",
      "id": 6,
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nodejs_version_info", "refId": "A", "format": "table", "instant": true }]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "id": 10,
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "process_resident_memory_bytes", "refId": "RSS", "legendFormat": "RSS" },
        { "expr": "nodejs_heap_size_used_bytes", "refId": "HEAP", "legendFormat": "Heap Used" },
        { "expr": "nodejs_external_memory_bytes", "refId": "EXT", "legendFormat": "External" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag",
      "id": 11,
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nodejs_eventloop_lag_seconds", "refId": "A", "legendFormat": "mean" },
        { "expr": "nodejs_eventloop_lag_p50_seconds", "refId": "B", "legendFormat": "p50" },
        { "expr": "nodejs_eventloop_lag_p99_seconds", "refId": "C", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "CPU Usage",
      "id": 12,
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(process_cpu_seconds_total[5m]) * 100",
        "refId": "A",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "type": "timeseries",
      "title": "Active Handles & Requests",
      "id": 13,
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nodejs_active_handles_total", "refId": "A", "legendFormat": "handles" },
        { "expr": "nodejs_active_requests_total", "refId": "B", "legendFormat": "requests" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["echofox"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EchoFox — Overview",
  "uid": "echofox-overview",
  "version": 1,
  "weekStart": ""
}
