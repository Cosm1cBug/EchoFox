{
  "name": "echofox",
  "version": "1.12.1",
  "description": "A production-grade WhatsApp bot built on Baileys 7.x — typed, observable, scalable.",
  "main": "src/core/bootstrap.js",
  "scripts": {
    "start": "node --enable-source-maps src/core/bootstrap.js",
    "dev": "node --enable-source-maps --trace-warnings src/core/bootstrap.js",
    "pm2": "pm2 start ecosystem.config.js",
    "lint": "eslint src scripts --max-warnings 0",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    "headers": "node scripts/add-license-headers.js",
    "headers:check": "node scripts/add-license-headers.js --check",
    "migrate": "node scripts/migrate.js",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "docs:commands": "node scripts/generate-command-docs.js",
    "test": "node scripts/run-tests.js",
    "test:contract": "node --test src/commands/__tests__/contract.test.js",
    "prepare": "husky || true",
    "build:dashboard": "node scripts/build-dashboard.js",
    "typecheck:dashboard": "cd dashboard && npx tsc -b --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "bot",
    "echofox",
    "whatsapp-bot",
    "agpl",
    "whiskeysockets"
  ],
  "author": {
    "name": "COSM1CBUG",
    "url": "https://github.com/Cosm1cBug"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cosm1cBug/EchoFox.git"
  },
  "bugs": {
    "url": "https://github.com/Cosm1cBug/EchoFox/issues",
    "email": "cosmicbug.me@pm.me"
  },
  "homepage": "https://cosm1cbug.github.io/echofox",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "src/",
    "scripts/",
    "ecosystem.config.js",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md",
    "DISCLAIMER.md",
    "SECURITY.md",
    "!src/config.js",
    "!src/@session/",
    "!src/store/runtime/"
  ],
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@google/generative-ai": "^0.24.1",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "@hapi/boom": "^10.0.1",
    "@distube/ytdl-core": "^4.16.5",
    "axios": "^1.18.0",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.4.1",
    "cfonts": "^3.3.0",
    "country-data": "^0.0.31",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "fast-xml-parser": "^5.9.3",
    "fluent-ffmpeg": "^2.1.3",
    "google-translate-api-x": "^10.7.2",
    "google-tts-api": "^2.0.2",
    "ioredis": "^5.4.1",
    "iso-3166-1-alpha-2": "^1.0.2",
    "iso-639-1": "^3.1.5",
    "jimp": "^1.6.1",
    "jsqr": "^1.4.0",
    "libphonenumber-js": "^1.13.3",
    "link-preview-js": "^3.0.5",
    "lru-cache": "^11.0.1",
    "mime-types": "^2.1.35",
    "moment-timezone": "^0.6.2",
    "mongoose": "^9.7.0",
    "msedge-tts": "^2.0.5",
    "music-metadata": "^11.13.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "node-datachannel": "^0.32.3",
    "node-webpmux": "^3.2.1",
    "ollama": "^0.6.3",
    "openai": "^6.44.0",
    "opossum": "^8.4.0",
    "p-queue": "^9.3.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-pretty": "^11.2.2",
    "prom-client": "^15.1.3",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.5",
    "socks-proxy-agent": "^8.0.4",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "spinnies": "^0.5.1",
    "wa-sticker-formatter": "^4.4.4",
    "yargs": "^18.0.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "wa-sticker-formatter": {
      "axios": "^1.7.7",
      "sharp": "^0.34.5",
      "file-type": "^22.0.1"
    },
    "google-tts-api": {
      "axios": "^1.7.7"
    },
    "form-data": "^4.0.6",
    "protobufjs": "^7.6.4"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "vitepress": "^1.6.4"
  }
}
