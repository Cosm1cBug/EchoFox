@'
* text=auto eol=lf

*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
'@ | Out-File -Encoding ascii .gitattributes

git add .gitattributes
git rm --cached -r .
git reset --hard
npm run headers
git add -A
git commit -m "fix: enforce LF line endings via .gitattributes"